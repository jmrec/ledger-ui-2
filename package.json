  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test:ts": "tsc --noEmit",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare",
    "serve": "./node_modules/@quasar/cli/bin/quasar.js serve ./dist/spa --port 9000",
    "api:sync": "pnpx openapi-typescript http://ledger:8080/v3/api-docs -o src/api/schema.d.ts",
    "tree": "tree -I 'node_modules|dist|.quasar|.git|.vscode|.pnpm-store' --dirsfirst"
  },
  "dependencies": {
    "@buf/jmrecondo_personal-server.bufbuild_es": "2.12.0-20260417153104-c66a7416c9cc.1",
    "@bufbuild/protobuf": "^2.12.0",
    "@connectrpc/connect-web": "^2.1.1",
    "@quasar/extras": "^1.16.4",
    "echarts": "^6.0.0",
    "pinia": "^3.0.1",
    "pinia-plugin-persistedstate": "^4.7.1",
    "quasar": "^2.16.0",
    "vue": "^3.5.22",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@quasar/app-vite": "^2.1.0",
    "@quasar/cli": "^2.5.0",
    "@types/node": "^20.5.9",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.4.0",
    "autoprefixer": "^10.4.2",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.4.0",
    "prettier": "^3.3.3",
    "typescript": "^5.9.2",
    "vite-plugin-checker": "^0.11.0",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.0.7"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  }
